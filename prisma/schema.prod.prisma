generator client {
  provider = "prisma-client-js"
}

// Production: Supabase PostgreSQL
// To deploy: npm run db:deploy:swap && prisma db push && prisma generate
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  passwordHash String
  tier         String    @default("free")
  auditsThisMonth Int    @default(0)
  auditsResetAt   DateTime @default(now())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  projects     Project[]
  sessions     Session[]
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  expiresAt DateTime
}

model Project {
  id        String   @id @default(cuid())
  name      String
  url       String
  type      String   @default("website")
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  audits    Audit[]
  competitors Competitor[]
  monitorSchedule MonitorSchedule?
  createdAt DateTime @default(now())
  updatedAt DateTime  @updatedAt
}

model Audit {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status        String   @default("pending")
  mode          String   @default("simple")
  healthScore   Float?
  performanceScore  Float?
  seoScore         Float?
  accessibilityScore Float?
  securityScore    Float?
  uxScore          Float?
  technologyScore  Float?
  contentScore     Float?
  findings      String   @default("{}")
  aiSummary     String   @default("{}")
  responseTime  Float?
  pageSize      Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime  @updatedAt
}

model Competitor {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  url         String
  lastAuditId String?
  comparison  String   @default("{}") // JSON: score deltas, feature comparison
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MonitorSchedule {
  id            String   @id @default(cuid())
  projectId     String   @unique
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  enabled       Boolean  @default(false)
  frequency     String   @default("weekly") // daily | weekly | monthly
  mode          String   @default("simple") // simple | deep
  lastRunAt     DateTime?
  nextRunAt     DateTime?
  alertOnDrop   Boolean  @default(true)
  dropThreshold Int      @default(10) // alert if health score drops by N points
  alertEmail    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}