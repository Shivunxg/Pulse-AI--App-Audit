{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "cp prisma/schema.prod.prisma prisma/schema.prisma && npx prisma generate && next build",
  "installCommand": "npm install",
  "regions": ["sin1"],
  "functions": {
    "src/app/api/projects/[id]/audits/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/projects/[id]/audits/[auditId]/route.ts": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/api/dashboard",
      "headers": [
        { "key": "Cache-Control", "value": "private, max-age=10, stale-while-revalidate=30" }
      ]
    },
    {
      "source": "/api/((?!dashboard).*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}