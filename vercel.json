{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "cp prisma/schema.prod.prisma prisma/schema.prisma && npx prisma generate && next build",
  "installCommand": "npm install",
  "outputDirectory": ".next/standalone",
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}